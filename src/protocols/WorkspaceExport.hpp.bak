#include "desktop/Workspace.hpp"
#include "helpers/Monitor.hpp"
#include "hyprland-workspace-export-v1.hpp"
#include "protocols/types/Buffer.hpp"
#include <vector>

class CMonitor;
class CWorkspace;

namespace Screenshare {
    class CScreenshareSession;
    class CScreenshareFrame;
};

class CWorkspaceExportClient {
  public:
    CWorkspaceExportClient(SP<CHyprlandWorkspaceExportManagerV1> resource_);

    bool good();

  private:
    SP<CHyprlandWorkspaceExportManagerV1> m_resource;
    WP<CWorkspaceExportClient>            m_self;

    wl_client* m_savedClient = nullptr;

    // CHANGED: Takes a workspaceName instead of a PHLWINDOW handle
    void                                  captureWorkspace(uint32_t frame, const std::string& workspaceName, int32_t overlayCursor);

    friend class CWorkspaceExportProtocol;
};


class CWorkspaceExportFrame {
  public:
    CWorkspaceExportFrame(SP<CHyprlandWorkspaceExportFrameV1> resource, WP<Screenshare::CScreenshareSession> session, bool overlayCursor);

    bool good();

  private:
    SP<CHyprlandWorkspaceExportFrameV1>  m_resource;
    WP<CWorkspaceExportFrame>            m_self;
    WP<CWorkspaceExportClient>           m_client;

    WP<Screenshare::CScreenshareSession> m_session;
    UP<Screenshare::CScreenshareFrame>   m_frame;

    CHLBufferReference                   m_buffer;
    Time::steady_tp                      m_timestamp;

    void shareFrame(wl_resource* buffer, bool ignoreDamage);

    friend class CWorkspaceExportProtocol;
    friend class CWorkspaceExportClient;
};


class CWorkspaceExportProtocol : public IWaylandProtocol {
  public:
    CWorkspaceExportProtocol(const wl_interface* iface, const int& ver, const std::string& name);

    void bindManager(wl_client* client, void* data, uint32_t ver, uint32_t id);
    void destroyResource(CWorkspaceExportClient* client);
    void destroyResource(CWorkspaceExportFrame* frame);

  private:
    std::vector<SP<CWorkspaceExportClient>> m_clients;
    std::vector<SP<CWorkspaceExportFrame>>  m_frames;

    friend class CWorkspaceExportClient;
    friend class CWorkspaceExportFrame;
};

namespace PROTO {
    inline UP<CWorkspaceExportProtocol> workspaceExport;
};
